*.pyc
__pycache__/
.venv/
.uv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
*.egg-info/
dist/
build/

# --- Node / Next.js ---------------------------------------------------------
node_modules/
.next/
out/

