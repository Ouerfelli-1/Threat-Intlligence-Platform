.DS_Store
*.log
*.bak
*.swp
*.swo
*.tmp
.idea/
.vscode/

# --- Claude Code runtime ----------------------------------------------------
# Per-user permissions + transient state. Not part of the project.
.claude/

# --- Design assets (mockups, not source) -----------------------------------
Design/

