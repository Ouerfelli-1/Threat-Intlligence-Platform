# ═══════════════════════════════════════════════════════
# TIP Environment Configuration
# Copy to .env and adjust as needed
# ═══════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
APP_NAME=Threat Intelligence Platform
DEBUG=true

# ── TIP Database (PostgreSQL) ────────────────────────
TIP_DB_HOST=localhost
TIP_DB_PORT=5433
TIP_DB_NAME=tip_db
TIP_DB_USER=tip_user
TIP_DB_PASSWORD=tip_password

# ── Wazuh REST API ───────────────────────────────────
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=wazuh
WAZUH_VERIFY_SSL=false

# ── MISP ─────────────────────────────────────────────
MISP_URL=https://localhost:9443
MISP_API_KEY=YOUR_MISP_API_KEY_HERE
MISP_VERIFY_SSL=false

# ── OpenCTI ──────────────────────────────────────────
OPENCTI_URL=http://localhost:8080
OPENCTI_API_KEY=YOUR_OPENCTI_API_KEY_HERE

# ── NVD API ──────────────────────────────────────────
# Optional: speeds up NVD queries (0.6 s vs 6 s rate limit)
NVD_API_KEY=
NVD_RATE_LIMIT=6.0
CVE_FETCH_DAYS=30

# ── Dummy Leak API ───────────────────────────────────
LEAK_API_URL=http://localhost:8081

# ── Recon Findings API ───────────────────────────────
RECON_FINDINGS_API_URL=http://localhost:8001

# ── Scheduler intervals (seconds) ───────────────────
SCHEDULER_ASSET_SYNC_HOURS=6
SCHEDULER_CVE_FETCH_HOURS=12
SCHEDULER_LEAK_CHECK_HOURS=1
SCHEDULER_IDS_INGEST_MINUTES=30
SCHEDULER_CORRELATION_HOURS=1
