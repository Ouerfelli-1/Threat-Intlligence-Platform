# TIP Platform — root environment
# Only these two values stay in .env permanently. Everything else lives in the secrets service.

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

POSTGRES_PASSWORD=tip_change_me

# development | production
TIP_ENV=development

# Set to false once auth and secrets services are running and seeded.
DISABLE_AUTH=true

BOOTSTRAP_ADMIN_USERNAME=admin

# Initial admin password — rotate from /me or /users after first login.
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Shared bootstrap token used during the secrets/auth chicken-and-egg dance.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRETS_BOOTSTRAP_TOKEN=
